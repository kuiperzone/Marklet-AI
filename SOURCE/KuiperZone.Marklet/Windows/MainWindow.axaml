<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:local-controls="clr-namespace:KuiperZone.Marklet.Controls"
        xmlns:chrome="clr-namespace:KuiperZone.Marklet.PixieChrome;assembly=KuiperZone.Marklet.PixieChrome"
        xmlns:pixie-controls="clr-namespace:KuiperZone.Marklet.PixieChrome.Controls;assembly=KuiperZone.Marklet.PixieChrome"

        x:CompileBindings="True"
        x:DataType="chrome:ChromeStyling"
        x:Class="KuiperZone.Marklet.Windows.MainWindow"

        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="800"

        Width="1200"
        MinWidth="500"

        Height="800"
        MinHeight="400"

        Icon="/Assets/marklet.128.png"
    >

    <Window.Styles>
        <Style Selector="TextBlock.status">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8 4 8 4"/>
            <Setter Property="FontSize" Value="{x:Static chrome:ChromeFonts.SmallFontSize}"/>
            <Setter Property="Foreground" Value="{x:Static chrome:ChromeStyling.GrayForeground}"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="MaxLines" Value="1"/>
        </Style>
    </Window.Styles>

    <Border Name="outerBorder"
        BorderBrush="{Binding BorderBrush}"
        BorderThickness="0 1 0 0">

        <Grid RowDefinitions="* Auto"
            Name="outerHorzGrid">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <local-controls:BufferBar Grid.Row="0" Grid.Column="0" Grid.RowSpan="99"
                Name="bufferBar"
                Background="{Binding BufferBarBrush}"
                BorderThickness="0 0 1 0"
                Padding="0 0 0 32"
                />

            <local-controls:MainMission Grid.Row="0" Grid.Column="1"
                Name="mission"
                Background="{Binding BackgroundLow}"
                />

            <!-- Note ColumnSpan -->
            <Grid Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"
                Name="innerVertGrid"
                RowDefinitions="* Auto"
                ColumnDefinitions="*">

                <!-- CONTENT VIEW -->
                <local-controls:DeckViewer Grid.Row="0" Grid.Column="0"
                    Name="deckViewer"/>

                <!-- overlay -->
                <local-controls:DeckOverlay Grid.Row="0" Grid.Column="0"
                    Name="overlay"/>

                <!-- PROMPT AREA -->
                <Border Grid.Row="1" Grid.Column="0"
                    Name="promptBar"
                    Padding="{x:Static chrome:ChromeSizes.HugePadding}"
                    Background="{Binding BackgroundLow}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="0 1 0 0">

                    <local-controls:Prompter Name="prompter"
                        DisabledEditBackground="{Binding Background}"
                        />
                </Border>

            </Grid>

            <Border Grid.Row="1" Grid.Column="1"
                Background="{Binding BackgroundLow}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="0 1 0 0">
                <TextBlock Name="missionStatus"
                    Classes="status"
                    Text="missionStatus"
                />
            </Border>

            <!-- Note ColumnSpan -->
            <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                Background="{Binding BackgroundLow}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="0 1 0 0">

                <Grid ColumnDefinitions="Auto * Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                        Name="leftStatus"
                        Classes="status"
                        Text="leftStatus"
                    />
                    <TextBlock Grid.Row="0" Grid.Column="2"
                        Name="rightStatus"
                        Classes="status"
                        Text="rightStatus"
                    />
                </Grid>
            </Border>

            <!-- Splitter after/after vertical grid-->
            <pixie-controls:HighSplitter Grid.Row="0" Grid.Column="2" Grid.RowSpan="999"
                Name="vertSplitter"
                Classes="vertical"
                Highlight="{Binding AccentBrush}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="1 0 0 0"
            />

        </Grid>

    </Border>

</Window>
