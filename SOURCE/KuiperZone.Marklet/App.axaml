<Application xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:vm="using:KuiperZone.Marklet.PixieChrome"
    xmlns:chrome="clr-namespace:KuiperZone.Marklet.PixieChrome;assembly=KuiperZone.Marklet.PixieChrome"

    x:CompileBindings="True"
    x:DataType="vm:ChromeStyling"
    x:Class="KuiperZone.Marklet.App"

    RequestedThemeVariant="Default"
    >

    <Application.Styles>

        <!-- IMPORTANT -->
        <FluentTheme/>

        <!-- INCLUDE STYLING IN SEPARATE LIB -->
        <StyleInclude Source="avares://KuiperZone.Marklet.PixieChrome/Assets/ChromeStyling.axaml"/>

    </Application.Styles>

</Application>